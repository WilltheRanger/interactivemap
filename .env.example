# DBHS Wayfinder — environment variables
# Copy to `.env` (gitignored) and fill in. The app uses ONLY the anon/publishable key (read-only via RLS).
# Never put the service-role key in the client.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-publishable-key

# Optional: where the Account "Report wrong info" link sends mail. Defaults to a placeholder.
VITE_FEEDBACK_EMAIL=wayfinder@dbhs.example

# Optional: Cloudinary, for the in-admin "Upload photo" button on locker panoramas. Both values are
# PUBLIC (the preset is unsigned) — safe in the client. Leave blank to fall back to pasting a URL.
# Setup: Cloudinary dashboard → Settings → Upload → add an *unsigned* upload preset.
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset
